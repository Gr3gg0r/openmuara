# Checkout store example configuration.
# Copy to .env and adjust. The Go server reads these from the environment.

# --- Server ---
ADDR=:8080
APP_URL=http://127.0.0.1:8080

# --- Payment methods ---
# Comma-separated allow-list of methods shown on the checkout page.
# This example is locked to ToyyibPay by default. Add fawry,stripe to re-enable
# the OpenMuara Fawry/Stripe emulators. Empty = toyyibpay.
PAYMENT_METHODS=toyyibpay

# --- OpenMuara emulator ---
# Base URL of the local OpenMuara emulator. TOYYIBPAY_BASE_URL falls back to this,
# so pointing at the emulator instead of the real gateway needs no extra config.
OPENMUARA_URL=http://127.0.0.1:9000

# --- ToyyibPay ---
# TOYYIBPAY_BASE_URL is the only value that changes between the real gateway
# and the OpenMuara emulator. Everything else (keys, category code) matches
# whichever backend you point at.
#
# Real ToyyibPay sandbox:
#   TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com
#   TOYYIBPAY_USER_SECRET_KEY=<your dev user secret key>
#   TOYYIBPAY_CATEGORY_CODE=<your dev category code>
#
# OpenMuara emulator (default):
#   TOYYIBPAY_BASE_URL=http://127.0.0.1:9000
#   TOYYIBPAY_USER_SECRET_KEY=muara-toyyibpay-secret
#   TOYYIBPAY_CATEGORY_CODE=cat_openmuara
TOYYIBPAY_BASE_URL=http://127.0.0.1:9000
TOYYIBPAY_USER_SECRET_KEY=muara-toyyibpay-secret
TOYYIBPAY_CATEGORY_CODE=cat_openmuara

# --- Mailpit ---
MAILPIT_HOST=127.0.0.1
MAILPIT_PORT=1025
MAIL_FROM=store@example.com
