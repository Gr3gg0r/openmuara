{
  "name": "openmuara-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual-baseline": "playwright test e2e/visual-baseline.spec.ts",
    "a11y:contrast": "node scripts/a11y-contrast-check.js",
    "bundle-size": "node scripts/check-bundle-size.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.9.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/preact": "^3.2.3",
    "jsdom": "^29.1.1",
    "terser": "^5.31.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-compression2": "^1.1.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
