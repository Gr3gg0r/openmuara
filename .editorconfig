root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 120

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.{css,scss}]
indent_size = 2

[*.sh]
indent_size = 2
end_of_line = lf

[Makefile]
indent_style = tab
